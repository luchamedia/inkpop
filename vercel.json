{
  "crons": [
    {
      "path": "/api/cron/daily-run",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/monthly-credits",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/process-queue",
      "schedule": "*/2 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/:path*"
    }
  ]
}
